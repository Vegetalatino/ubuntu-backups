# Secrets de ejemplo - NO incluir datos reales
# Copiar a /root/.secrets/.env y ajust los valores

GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_secret_aqui
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui
Rclone_remote=gdrive  # Google Drive remote name
BORG_PASSPHRASE=Bakuman2612#@mo  # Contraseña del backup Borg
MAX_DRIVE_GB=10  # Límite en Google Drive (ajustar)
KEEP_DAILY=7      # Mantener 7 días
KEEP_WEEKLY=4     # Mantener 4 semanas  
KEEP_MONTHLY=6    # Mantener 6 meses
